# Everything not in package.json "files" should stay off npm.
# Whitelist: dist/, src/, README.md, LICENSE

# Repository & CI (GitHub only)
.git/
.github/
.gitignore
.npmignore

# Agent & internal dev context
AGENTS.md
.cursor/
docs/
scripts/

# Build tooling & config
vite.config.js
index.html

# Version & changelog (consumers use npm version / registry metadata)
VERSION
CHANGELOG.md

# Development & testing
node_modules/
*.test.js
*.spec.js
coverage/
.nyc_output/

# Environment & secrets
.env
.env.*
.npmrc
.npmrc.local
*.pem
*.key
secrets/

# Logs & backups
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backups/
*.backup
*.bak

# IDE & OS
.vscode/
.idea/
.kiro/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Local artifacts
*.tgz
