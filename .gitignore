# Dependencies
node_modules/

# Build outputs (generated by `npm run build` / CI; not source)
dist/

# Internal documentation (operator manuals, project brain, release notes)
# Public user docs live in README.md and CHANGELOG.md at repo root.
docs/

# Environment & secrets — never commit tokens or local overrides
.env
.env.*
!.env.example
.npmrc
.npmrc.local
*.pem
*.key
*.p12
*.credentials
secrets/

# Logs & debug output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test & coverage artifacts
coverage/
.nyc_output/
test-results/

# IDE & editor local settings
.vscode/
.idea/
.kiro/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Cursor local/session state (project rules & skills in .cursor/ are committed)
.cursor/plans/
.cursor/**/*.log

# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Backups & temp files
backups/
*.backup
*.bak
*.tmp
*.temp
.cache/
.parcel-cache/
.turbo/

# Local npm pack tarballs (from `npm pack`)
*.tgz

# Optional local overrides
*.local
