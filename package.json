{
  "name": "shutters-accordion",
  "version": "1.3.0",
  "description": "Simple vanilla JavaScript accordion library — zero dependencies, CSS Grid animation, ARIA, under 2KB gzip.",
  "main": "dist/shutters.umd.js",
  "module": "dist/shutters.es.js",
  "types": "dist/shutters.d.ts",
  "style": "dist/core.css",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/shutters.d.ts",
      "import": "./dist/shutters.es.js",
      "require": "./dist/shutters.umd.js"
    },
    "./auto": {
      "types": "./dist/shutters.d.ts",
      "import": "./dist/shutters.auto.es.js",
      "require": "./dist/shutters.auto.umd.js"
    },
    "./core.css": "./dist/core.css",
    "./theme.css": "./dist/theme.css",
    "./css": "./dist/core.css",
    "./style.css": "./dist/core.css"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byronjohnson/shutters-accordion.git"
  },
  "bugs": {
    "url": "https://github.com/byronjohnson/shutters-accordion/issues"
  },
  "homepage": "https://shuttersjs.com/",
  "keywords": [
    "simple-vanilla-javascript-accordion-library",
    "vanilla-javascript-accordion-library",
    "accordion",
    "accordion-component",
    "accordion-widget",
    "collapse",
    "collapsible",
    "collapsible-panels",
    "expand-collapse",
    "toggle",
    "toggle-panel",
    "ui",
    "ui-component",
    "component",
    "vanilla-js",
    "vanilla-javascript",
    "javascript",
    "css",
    "css-grid",
    "css-animation",
    "accessible",
    "accessibility",
    "a11y",
    "aria",
    "wcag",
    "keyboard-navigation",
    "screen-reader",
    "lightweight",
    "minimal",
    "tiny",
    "small",
    "no-dependencies",
    "dependency-free",
    "zero-dependencies",
    "framework-agnostic",
    "web-component",
    "faq",
    "faq-accordion",
    "expandable",
    "disclosure",
    "smooth-animation",
    "60fps",
    "shutters"
  ],
  "author": "Byron Johnson",
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^26.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "verify:vanilla": "node scripts/verify-vanilla.mjs",
    "test": "npm run verify:vanilla && vitest run",
    "test:watch": "vitest",
    "build": "vite build && vite build --config vite.config.auto.js && node scripts/build-theme-css.mjs && cp src/shutters.d.ts dist/shutters.d.ts",
    "size": "npm run build && node scripts/check-size.mjs",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "agent:sync": "node scripts/generate-agent-context.mjs",
    "version:sync": "node scripts/sync-version.js",
    "preversion": "npm run version:sync",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
